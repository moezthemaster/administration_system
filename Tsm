9. Script exemple (automatisation)

```bash
#!/bin/bash
# Sauvegarde quotidienne avec logs

DATE=$(date +%Y%m%d)
LOG=/var/log/tsm_backup.log

echo "=== Début sauvegarde $DATE ===" >> $LOG
dsmc incremental /home/moi/documents -subdir=yes >> $LOG 2>&1

if [ $? -eq 0 ]; then
    echo "Sauvegarde OK" >> $LOG
else
    echo "ERREUR sauvegarde" >> $LOG
    # Envoyer un mail d'alerte ici
fi
```

